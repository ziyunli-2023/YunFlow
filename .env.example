# AI News Monitor Configuration
# All variables are optional - features will be skipped if not configured

# X (Twitter) API — only Bearer Token needed for reading public timelines
# Get from: https://developer.twitter.com/en/portal/dashboard
# Leave empty to skip tweet monitoring
X_BEARER_TOKEN=

# Email notifications (Gmail SMTP)
# App Password: Google Account → Security → 2-Step Verification → App Passwords
# Leave empty to disable email notifications
EMAIL_SENDER=
EMAIL_APP_PASSWORD=
EMAIL_RECIPIENT=
# Local-only login testing: prints magic links / codes to server logs instead of SMTP.
# Only works with BASE_URL on localhost or 127.0.0.1.
AUTH_DEBUG_EMAILS=false

# DeepSeek API key (for auto-translation of English titles/summaries to Chinese)
# Get from: https://platform.deepseek.com/api_keys
# Leave empty to disable translation
DEEPSEEK_API_KEY=

# Finnhub API key (for the earnings calendar at /earnings)
# Free tier covers earnings + IPO calendars (60 req/min)
# Get from: https://finnhub.io/dashboard
# Leave empty to show only US macro events from data/us_macro_events.json
FINNHUB_API_KEY=

# Web dashboard port (default 8000)
# Note: When using Docker, nginx will proxy to this port
WEB_PORT=8000

# Stripe VIP subscriptions
# Create a monthly recurring Price in Stripe and paste its price_... ID here.
# Use the webhook signing secret from the Stripe endpoint that points to /stripe/webhook.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_VIP_PRICE_ID=
